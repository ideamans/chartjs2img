{
  "name": "chartjs2img",
  "version": "0.2.0",
  "description": "Render Chart.js charts to images via CLI or HTTP API using headless Chrome",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "chartjs2img": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts serve",
    "build": "bun build src/index.ts --compile --outfile chartjs2img",
    "start": "bun run src/index.ts serve",
    "cli": "bun run src/index.ts"
  },
  "dependencies": {
    "puppeteer-core": "^24.40.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
